+struct growing_file_state {
+    bool enabled;
+    int64_t last_reopen_time;   // mp_time_ns() of last reopen
+};
 
 static int fill_buffer(stream_t *s, void *buffer, int max_len)
 {
     AVIOContext *avio = s->priv;
+    struct growing_file_state *gfs = s->growing_file_state;
     int r = avio_read_partial(avio, buffer, max_len);
+    if (r > 0)
+        return r;
+    if (!gfs || !gfs->enabled)
+        return -1;
+
+    // Growing file: EOF reached. Only reopen if at least 2 seconds have
+    // passed since the last reopen (like Kodi's sleep-2-then-reopen).
+    // Between reopens, return -1 to let demuxer-force-retry-eof handle
+    // the 1-second throttled wait.
+    int64_t now = mp_time_ns();
+    if (gfs->last_reopen_time > 0 &&
+        (now - gfs->last_reopen_time) < MP_TIME_S_TO_NS(2))
+        return -1;
+
+    int64_t pos = avio_tell(avio);
+    if (pos < 0)
+        return -1;
+
+    gfs->last_reopen_time = now;
+    MP_VERBOSE(s, "Growing file: EOF at %"PRId64", reopening\n", pos);
+
+    if (reopen_avio(s, pos) < 0) {
+        MP_WARN(s, "Growing file: reopen failed\n");
+        return -1;
+    }
+
+    avio = s->priv;
+    r = avio_read_partial(avio, buffer, max_len);
     return (r <= 0) ? -1 : r;
 }
 
+static int reopen_avio(stream_t *s, int64_t pos)
+{
+    AVIOContext *old_avio = s->priv;
+
+    // Open the new connection BEFORE closing the old one, so s->priv is
+    // never NULL. Other threads (read_icy, control) read s->priv without
+    // locks and would crash on a NULL dereference.
+    AVDictionary *dict = NULL;
+    mp_setup_av_network_options(&dict, NULL, s->global, s->log);
+
+    AVIOInterruptCB cb = {
+        .callback = interrupt_cb,
+        .opaque = s,
+    };
+
+    AVIOContext *avio = NULL;
+    int err = avio_open2(&avio, s->url, AVIO_FLAG_READ, &cb, &dict);
+    av_dict_free(&dict);
+    if (err < 0) {
+        MP_WARN(s, "Growing file: reopen failed: %d\n", err);
+        return -1;
+    }
+
+    // Atomic swap: s->priv is never NULL
+    s->priv = avio;
+    s->seekable = avio->seekable & AVIO_SEEKABLE_NORMAL;
+    s->seek = s->seekable ? seek : NULL;
+
+    if (old_avio)
+        avio_close(old_avio);
+
+    if (pos > 0) {
+        int64_t new_pos = avio_seek(avio, pos, SEEK_SET);
+        if (new_pos < 0)
+            MP_WARN(s, "Growing file: seek to %"PRId64" failed\n", pos);
+    }
+
+    return 0;
+}
