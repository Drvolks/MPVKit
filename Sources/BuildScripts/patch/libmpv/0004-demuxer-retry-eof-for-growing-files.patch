diff --git a/demux/demux.c b/demux/demux.c
index d1accba..cf95ca1 100644
--- a/demux/demux.c
+++ b/demux/demux.c
@@ -124,6 +124,7 @@ const struct m_sub_options demux_conf = {
         {"metadata-codepage", OPT_STRING(meta_cp)},
         {"autocreate-playlist", OPT_CHOICE(autocreate_playlist,
             {"no", 0}, {"filter", 1}, {"same", 2})},
+        {"demuxer-force-retry-eof", OPT_BOOL(force_retry_eof)},
         {0}
     },
     .size = sizeof(struct demux_opts),
@@ -193,6 +194,7 @@ struct demux_internal {
 
     bool warned_queue_overflow;
     bool eof;                   // whether we're in EOF state
+    int eof_retry_count;        // for force_retry_eof: attempts before real EOF
     double min_secs;
     double hyst_secs;           // stop reading till there's hyst_secs remaining
     bool hyst_active;
@@ -2252,6 +2254,7 @@ static bool read_packet(struct demux_internal *in)
     // Actually read a packet. Drop the lock while doing so, because waiting
     // for disk or network I/O can take time.
     in->reading = true;
+    bool retry_eof = in->d_user->opts->force_retry_eof;
     in->after_seek = false;
     in->after_seek_to_start = false;
     mp_mutex_unlock(&in->lock);
@@ -2272,19 +2275,39 @@ static bool read_packet(struct demux_internal *in)
     }
 
     if (!in->seeking) {
-        if (eof) {
+        if (eof && retry_eof && in->eof_retry_count < 10) {
+            // Growing file: don't propagate EOF to the decoder chain.
+            // Just pause reading and let the demux thread retry on its
+            // next wakeup (~1s).  Meanwhile ffmpeg's reconnect_at_eof
+            // will reconnect and fetch newly written data.
+            in->eof_retry_count++;
+            if (in->eof_retry_count == 1 || (in->eof_retry_count % 5) == 0)
+                MP_VERBOSE(in, "EOF suppressed (retry %d/10), "
+                           "waiting for new data...\n", in->eof_retry_count);
+            in->reading = false;
+            // DON'T set in->eof or mark streams — decoder keeps consuming
+            // buffered data while we wait for reconnect.
+        } else if (eof) {
             for (int n = 0; n < in->num_streams; n++)
                 mark_stream_eof(in->streams[n]->ds);
-            // If we had EOF previously, then don't wakeup (avoids wakeup loop)
             if (!in->eof) {
                 if (in->wakeup_cb)
                     in->wakeup_cb(in->wakeup_cb_ctx);
                 mp_cond_signal(&in->wakeup);
                 MP_VERBOSE(in, "EOF reached.\n");
             }
+            in->eof = eof;
+            in->reading = false;
+        } else {
+            // Successful read — reset retry counter
+            if (in->eof_retry_count > 0) {
+                MP_VERBOSE(in, "EOF retry recovered after %d attempts.\n",
+                           in->eof_retry_count);
+                in->eof_retry_count = 0;
+            }
+            in->eof = false;
+            in->reading = true;
         }
-        in->eof = eof;
-        in->reading = !eof;
     }
     return true;
 }
