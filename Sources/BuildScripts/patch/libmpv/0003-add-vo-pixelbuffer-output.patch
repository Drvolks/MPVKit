+#ifndef MPV_RENDER_PIXELBUFFER_H_
+#define MPV_RENDER_PIXELBUFFER_H_
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/*
+ * Callback type for receiving decoded video frames as CVPixelBufferRef.
+ *
+ * Called on mpv's VO thread. The callback must not block for long.
+ *
+ * @param ctx       User-provided context pointer.
+ * @param pixelbuffer   CVPixelBufferRef (caller retains ownership; callback
+ *                      must CFRetain if it needs to keep it beyond the call).
+ * @param pts       Presentation timestamp in seconds (from mpv's timeline).
+ * @param duration  Frame duration in seconds.
+ */
+typedef void (*mpv_pixelbuffer_frame_cb)(void *ctx, void *pixelbuffer,
+                                         double pts, double duration);
+
+/*
+ * Callback type for video reconfiguration events (resolution/format change).
+ *
+ * @param ctx   User-provided context pointer.
+ * @param w     New video width in pixels.
+ * @param h     New video height in pixels.
+ * @param fmt   mpv image format (IMGFMT_*).
+ */
+typedef void (*mpv_pixelbuffer_reconfig_cb)(void *ctx, int w, int h, int fmt);
+
+/*
+ * Register callbacks for the "pixelbuffer" video output.
+ *
+ * Must be called before mpv_initialize(). Set vo=pixelbuffer and
+ * hwdec=videotoolbox for zero-copy CVPixelBuffer delivery.
+ *
+ * @param frame_cb      Frame delivery callback (required).
+ * @param frame_ctx     Context pointer passed to frame_cb.
+ * @param reconfig_cb   Reconfig callback (optional, may be NULL).
+ * @param reconfig_ctx  Context pointer passed to reconfig_cb.
+ */
+void mpv_pixelbuffer_set_callbacks(mpv_pixelbuffer_frame_cb frame_cb,
+                                   void *frame_ctx,
+                                   mpv_pixelbuffer_reconfig_cb reconfig_cb,
+                                   void *reconfig_ctx);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* MPV_RENDER_PIXELBUFFER_H_ */
diff --git forkSrcPrefix/video/out/vo_pixelbuffer.c forkDstPrefix/video/out/vo_pixelbuffer.c
